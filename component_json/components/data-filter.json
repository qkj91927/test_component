{
  "id": "data_filter",
  "name": "数据筛选 DataFilter",
  "category": "数据",
  "description": "页面中用于分类切换、条件筛选与层级导航的组合组件族，包含页签、分段选择、下拉筛选、标签、面包屑五种子组件类型。",

  "totalVariants": 16,

  "variants": {
    "A_tab": {
      "name": "页签 Tab",
      "items": [
        { "id": "A1", "name": "四页签", "count": 4, "height": 48, "mode": "equal" },
        { "id": "A2", "name": "五页签", "count": 5, "height": 48, "mode": "equal" },
        { "id": "A3", "name": "六页签", "count": 6, "height": 48, "mode": "equal" },
        { "id": "A4", "name": "横滑", "count": 8, "height": 48, "mode": "scroll", "padding": "0 16px", "gap": 24 }
      ],
      "layout": {
        "containerWidth": 428,
        "background": "white",
        "bottomBorder": { "height": 0.5, "color": { "token": "border_standard", "value": "rgba(0, 0, 0, 0.10)" } },
        "overflow": "hidden"
      },
      "style": {
        "text": { "fontSize": 16, "lineHeight": 22, "font": "PingFang SC" },
        "unselected": { "fontWeight": 400, "color": { "token": "text_primary", "value": "rgba(0, 0, 0, 0.90)" } },
        "selected": { "fontWeight": 500, "color": { "token": "text_primary", "value": "rgba(0, 0, 0, 0.90)" } },
        "indicator": { "width": 32, "height": 3, "radius": 1.5, "color": { "token": "brand_standard", "value": "#0099FF" }, "position": "absolute bottom:0" }
      }
    },

    "B_segment": {
      "name": "分段选择 Segment",
      "items": [
        { "id": "B1", "name": "二选项", "count": 2 },
        { "id": "B2", "name": "三选项", "count": 3 },
        { "id": "B3", "name": "四选项", "count": 4 },
        { "id": "B4", "name": "五选项", "count": 5 }
      ],
      "layout": {
        "outerRow": { "display": "inline-flex", "background": "white", "padding": "6px 16px" },
        "container": { "display": "inline-flex", "background": { "token": "fill_standard_primary", "value": "rgba(13, 16, 49, 0.04)" }, "radius": 6 },
        "barHeight": 36,
        "itemWidth": 52,
        "totalWidth": "52.5 × n"
      },
      "style": {
        "divider": { "width": 0.5, "height": 16, "color": { "token": "border_standard", "value": "rgba(0, 0, 0, 0.10)" }, "selectedAdjacentHidden": true },
        "text": { "fontSize": 14, "lineHeight": 20, "font": "PingFang SC" },
        "unselected": { "fontWeight": 400, "color": "#6A6B6D" },
        "selected": { "fontWeight": 500, "color": "#1A1C1E" }
      }
    },

    "C_dropdown": {
      "name": "下拉筛选 Dropdown",
      "items": [
        { "id": "C1", "name": "一按钮", "count": 1 }
      ],
      "layout": {
        "outerRow": { "display": "inline-flex", "background": "white", "padding": "6px 16px", "boxSizing": "border-box" },
        "container": { "display": "inline-flex", "background": { "token": "fill_standard_primary", "value": "rgba(13, 16, 49, 0.04)" }, "radius": 6 },
        "buttonHeight": 36,
        "buttonPadding": "0 12px",
        "innerGap": 4
      },
      "style": {
        "text": { "fontSize": 14, "lineHeight": 20, "fontWeight": 400, "color": { "token": "text_primary", "value": "rgba(0, 0, 0, 0.90)" } },
        "arrow": { "size": 14, "fill": "#1A1A1A" }
      },
      "note": "仅包含按钮，不包含弹窗菜单。点击后由 Menu 组件承担弹窗"
    },

    "D_tag": {
      "name": "标签 Tag",
      "items": [
        { "id": "D1", "name": "单行横滑", "count": 6, "height": 56, "tagHeight": 40, "mode": "scroll", "tagPadding": "0 16px" },
        { "id": "D2", "name": "单行4个", "count": 4, "height": 56, "tagHeight": 40, "mode": "tile" },
        { "id": "D3", "name": "单行3个", "count": 3, "height": 56, "tagHeight": 40, "mode": "tile" },
        { "id": "D4", "name": "单行2个", "count": 2, "height": 56, "tagHeight": 40, "mode": "tile" },
        { "id": "D5", "name": "双行2个", "count": 2, "height": 78, "tagHeight": 62, "mode": "tile", "hasDescription": true }
      ],
      "layout": {
        "containerWidth": 428,
        "background": "white",
        "tilePadding": "8px 16px",
        "scrollPadding": "8px 0",
        "tagAreaWidth": 396,
        "tagRadius": 12,
        "tagBg": { "token": "fill_standard_primary", "value": "rgba(13, 16, 49, 0.04)" },
        "tagGap": 8,
        "tileTagWidth": "(396 - (n-1)×8) / n"
      },
      "style": {
        "singleLineText": { "fontSize": 15, "lineHeight": 20, "font": "PingFang SC" },
        "unselected": { "fontWeight": 400, "color": "rgba(60,60,67,0.76)" },
        "selected": { "fontWeight": 500, "color": "rgba(0,0,0,0.90)" },
        "doubleLineTitle": { "fontSize": 15, "lineHeight": 20 },
        "doubleLineDesc": { "fontSize": 14, "lineHeight": 20, "fontWeight": 400 },
        "doubleLineDescSelected": { "color": "rgba(60,60,67,0.76)" },
        "doubleLineDescUnselected": { "color": "rgba(60,60,67,0.56)" }
      }
    },

    "E_breadcrumb": {
      "name": "面包屑 Breadcrumb",
      "items": [
        { "id": "E1", "name": "标准", "levels": 4, "height": 48 },
        { "id": "E2", "name": "超限渐隐", "levels": 6, "height": 48, "overflowMask": true }
      ],
      "layout": {
        "containerWidth": 428,
        "background": "white",
        "standardPadding": "0 16px",
        "E2_clipWidth": 412,
        "E2_offset": -92,
        "E2_maskWidth": 24,
        "E2_maskGradient": "linear-gradient(to right, white 49.5%, transparent 100%)"
      },
      "style": {
        "text": { "fontSize": 14, "lineHeight": 20, "fontWeight": 500, "whiteSpace": "nowrap", "flexShrink": 0 },
        "middleLevel": { "color": { "token": "text_secondary", "value": "rgba(60, 60, 67, 0.76)" } },
        "lastLevel": { "color": { "token": "text_primary", "value": "rgba(0, 0, 0, 0.90)" } },
        "separator": { "size": 12, "color": "rgba(60,60,67,0.75)", "margin": "0 8px" }
      }
    }
  },

  "compositionRules": {
    "segmentAndDropdown": "外层 inline-flex, 白色背景, padding: 6px 16px, 宽度自适应",
    "sameLine": "相同/不同类型可同行排列，间距 16px"
  },

  "interaction": {
    "segmentDivider": "选中项左右相邻分隔线 opacity: 0，其余恢复 1",
    "tabIndicator": "仅 .selected 项指示器可见",
    "breadcrumbMask": "E2 通过 .overflow-left class 控制左侧遮罩 (transition: opacity 0.2s)",
    "scrollMode": "A4/D1 支持横向滚动，scrollbar 隐藏，-webkit-overflow-scrolling: touch"
  },

  "usage": {
    "tab": "顶部或区域级信息分类切换",
    "segment": "同级视图的模式切换（日/周/月/年）",
    "dropdown": "条件筛选或排序切换，点击后弹出菜单",
    "tag": "分类标签入口",
    "breadcrumb": "多级层级导航回溯"
  }
}
