{
  "$schema": "design-system-index",
  "$version": "1.0.0",
  "$description": "移动端设计系统 UI IR — 全局索引与设计 Token",

  "device": {
    "width": 428,
    "statusBarHeight": 54,
    "homeBarHeight": 34,
    "homeBarIndicator": { "width": 168.92, "height": 5.71, "radius": 2.85 },
    "screenHeight": 926,
    "platform": "iOS",
    "font": "PingFang SC"
  },

  "tokens": {
    "color": {
      "text_primary": "rgba(0, 0, 0, 0.90)",
      "text_secondary": "rgba(60, 60, 67, 0.76)",
      "text_tertiary": "rgba(60, 60, 67, 0.56)",
      "text_quaternary": "rgba(60, 60, 67, 0.26)",
      "text_link": "#214CA5",
      "text_allwhite": "#FFFFFF",
      "brand_standard": "#0099FF",
      "brand_pressed": "#008AE5",
      "feedback_error": "#F74C30",
      "separator": "rgba(0, 0, 0, 0.08)",
      "border_standard": "rgba(0, 0, 0, 0.10)",
      "bg_page": "#F0F0F2",
      "bg_item": "#FFFFFF",
      "bg_secondary": "#F3F3F7",
      "overlay_dark": "rgba(0, 0, 0, 0.50)",
      "overlay_dialog": "rgba(0, 0, 0, 0.40)",
      "btn_bg": "rgba(116, 116, 128, 0.08)",
      "fill_tertiary": "rgba(118, 118, 128, 0.12)",
      "fill_standard_primary": "rgba(13, 16, 49, 0.04)",
      "fill_pressed": "rgba(0, 0, 0, 0.04)",
      "fill_standard_brand": "rgba(0, 81, 254, 0.04)",
      "icon_secondary": "#929296",
      "icon_primary": "#1A1A1A"
    },
    "typography": {
      "largeTitle": { "size": 26, "weight": 600, "lineHeight": 34 },
      "title1": { "size": 22, "weight": 500, "lineHeight": 28 },
      "title2": { "size": 18, "weight": 500, "lineHeight": 26 },
      "headline": { "size": 17, "weight": 600, "lineHeight": 24 },
      "body": { "size": 17, "weight": 400, "lineHeight": 24 },
      "callout": { "size": 16, "weight": 400, "lineHeight": 22 },
      "subhead": { "size": 15, "weight": 400, "lineHeight": 20 },
      "footnote": { "size": 14, "weight": 400, "lineHeight": 20 },
      "caption1": { "size": 12, "weight": 400, "lineHeight": 17 },
      "caption2": { "size": 10, "weight": 400, "lineHeight": 14 }
    },
    "spacing": {
      "pagePadding": 16,
      "iconGap": 12,
      "sectionGap": 8,
      "gridUnit": 4
    },
    "radius": {
      "card": 12,
      "cardLarge": 24,
      "button": 18,
      "buttonPill": 9999,
      "thumbSmall": 4,
      "thumbMedium": 8,
      "thumbLarge": 16,
      "overlay": 20,
      "actionSheet": 16,
      "dialog": 14,
      "menu": 12,
      "input": 12,
      "segment": 6
    },
    "shadow": {
      "dialog": "0 8px 32px rgba(0,0,0,0.12)",
      "menu": "0 8px 32px rgba(0,0,0,0.12)"
    },
    "animation": {
      "pressIn": { "duration": 100, "easing": "ease-out" },
      "pressOut": { "duration": 150, "easing": "ease-out" },
      "switchToggle": { "duration": 200, "easing": "ease-out" },
      "childExpand": { "duration": 250, "easing": "ease-in-out" },
      "childCollapse": { "duration": 200, "easing": "ease-in" },
      "halfScreenIn": { "duration": 420, "easing": "cubic-bezier(0.32, 0.72, 0.35, 1)" },
      "halfScreenOut": { "duration": 300 },
      "menuIn": { "duration": 200, "easing": "ease-out", "transform": "scale(0.9) → scale(1)" },
      "menuOut": { "duration": 150, "easing": "ease-in", "transform": "scale(1) → scale(0.9)" }
    }
  },

  "components": {
    "导航": [
      { "id": "navbar", "name": "导航栏 NavBar", "file": "components/navbar.json" },
      { "id": "hs_navbar", "name": "半屏导航栏 HalfScreen NavBar", "file": "components/hs-navbar.json" }
    ],
    "数据": [
      { "id": "list", "name": "通栏式列表 Plain List", "file": "components/plain-list.json" },
      { "id": "form", "name": "卡片式列表 Grouped List", "file": "components/grouped-list.json" },
      { "id": "text_block", "name": "文本块 TextBlock", "file": "components/text-block.json" },
      { "id": "image_block", "name": "图片块 ImageBlock", "file": "components/image-block.json" },
      { "id": "data_filter", "name": "数据筛选 DataFilter", "file": "components/data-filter.json" },
      { "id": "card", "name": "卡片 Card", "file": "components/card.json" },
      { "id": "grid", "name": "宫格 Grid", "file": "components/grid.json" },
      { "id": "divider_spacing", "name": "分隔与间距 Divider & Spacing", "file": "components/divider-spacing.json" }
    ],
    "操作": [
      { "id": "button", "name": "按钮 Button", "file": "components/button.json" },
      { "id": "action", "name": "操作组合 ActionCombo", "file": "components/action-combo.json" },
      { "id": "menu", "name": "菜单 Menu", "file": "components/menu.json" },
      { "id": "search", "name": "搜索框 Search", "file": "components/search.json" },
      { "id": "textfield", "name": "输入框 Textfield", "file": "components/textfield.json" }
    ],
    "模态": [
      { "id": "action_sheet", "name": "操作面板 ActionSheet", "file": "components/action-sheet.json" },
      { "id": "dialog", "name": "对话框 Dialog", "file": "components/dialog.json" },
      { "id": "half_screen_overlay", "name": "半屏浮层 HalfScreenOverlay", "file": "components/half-screen-overlay.json" }
    ]
  },

  "composition": {
    "pageStructure": {
      "layers": ["StatusBar (54px)", "NavBar (44px)", "ContentArea (scrollable)", "TabBar (optional)", "Modal (optional)"],
      "safeArea": { "top": 54, "bottom": 34 }
    },
    "rules": [
      "同一列表视图内所有行的 L/C/R 组合必须一致（单一类型原则）",
      "不同类型的列表通过 Tab/Segment 等视图级切换控件切换",
      "模态组件（ActionSheet/Dialog/HalfScreenOverlay）不可嵌套",
      "半屏浮层内可嵌入非模态组件（列表、表单、按钮、文本块、图片块等）",
      "卡片式列表同一卡片内允许不同 L×R 类型混排",
      "分段选择和下拉筛选可与其他组件同行排列，间距 16px",
      "分割线不在列表最后一行底部显示",
      "间距高度为 4px 整数倍，遵循 4px 网格系统"
    ],
    "modalBehavior": {
      "ActionSheet": { "position": "bottom", "overlay": true, "closeOnOverlay": true },
      "Dialog": { "position": "center", "overlay": true, "closeOnOverlay": false },
      "HalfScreenOverlay": { "position": "bottom", "overlay": true, "closeOnOverlay": true },
      "Menu": { "position": "nearTrigger", "overlay": false, "offset": 6 }
    }
  }
}
