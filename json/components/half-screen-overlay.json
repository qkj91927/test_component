{
  "id": "half_screen_overlay",
  "name": "半屏浮层 HalfScreenOverlay",
  "category": "模态",
  "description": "从屏幕底部弹出、约占半屏高度的模态容器组件，用于承载二级内容、表单、选择器等场景。分为标准型（关闭按钮导航栏）和把手型（拖拽把手条）两种子组件。",
  "spec": "md/HALF_SCREEN_OVERLAY_COMPONENT_SPEC.md",

  "totalVariants": 2,

  "variants": [
    {
      "id": "HSO-A",
      "name": "标准型",
      "topArea": "半屏导航栏（默认A3，可替换为A1-A4/B1-B3任意变体，高度54px，A2为65px）",
      "heightRange": { "min": 360, "max": 720, "default": 420 },
      "contentHeight": "sheetHeight - navbarHeight(默认54，A2为65) - 34(HomeBar)",
      "contentHeightDefault": 332,
      "closeMethods": ["下滑手势", "点击遮罩区域", "点击关闭Icon", "点击操作区功能按钮(可选)"]
    },
    {
      "id": "HSO-B",
      "name": "把手型",
      "topArea": "拖拽把手条（20px，居中指示条36×5px）",
      "heightRange": { "halfScreen": "75vh", "fullScreen": "100vh" },
      "contentHeight": "75vh - 20(把手条) - 34(HomeBar)",
      "fullscreenSupport": true,
      "fullscreenNavbar": {
        "description": "系统状态栏 + NavBar（把手条淡出，导航栏淡入，交叉过渡）",
        "L": "L3(关闭✕，必选，不可更改)",
        "C": "可按业务配置(默认C0空白，可选C1标题/C2下拉标题等)",
        "R": "可按业务配置(默认R0空白，可选R1图标/R3操作文字等)",
        "spec": "遵循 NAVBAR_COMPONENT_SPEC.md"
      },
      "closeMethods": ["下滑手势", "右滑手势", "点击蒙层", "点击操作区功能按钮", "全屏态点击关闭按钮"],
      "gestures": {
        "swipeDownThreshold": 100,
        "swipeRightThreshold": 100,
        "damping": 0.85,
        "horizontalToVerticalRatio": 0.6,
        "fullscreenSnapThreshold": "top < 100px",
        "elasticDamping": 0.2
      }
    }
  ],

  "layout": {
    "width": 428,
    "topRadius": 20,
    "overlay": { "token": "overlay-modal", "value": "rgba(0, 0, 0, 0.50)" },
    "panelBackground": "white"
  },

  "style": {
    "closeButton": {
      "size": 30,
      "radius": "50%",
      "background": "rgba(0,0,0,0.04)",
      "iconSize": 16,
      "iconColor": { "token": "text-primary", "value": "rgba(0, 0, 0, 1.0)" },
      "position": "right, padding 16px"
    },
    "handleBar": {
      "areaHeight": 20,
      "indicatorSize": [36, 5],
      "indicatorRadius": 2.5,
      "indicatorColor": "rgba(60,60,67,0.30)",
      "align": "center"
    }
  },

  "interaction": {
    "appear": {
      "panel": "从底部滑入",
      "overlay": "同步淡入",
      "curve": "cubic-bezier(0.32, 0.72, 0.35, 1)",
      "duration": 420
    },
    "dismiss": {
      "panel": "向下滑出",
      "overlay": "同步淡出",
      "duration": 300,
      "curve": "cubic-bezier(0.32, 0.72, 0.35, 1)"
    },
    "contentScroll": {
      "overflow": "auto",
      "touchScrolling": "-webkit-overflow-scrolling: touch",
      "scrollTopDismiss": "滚动到顶部后继续下拉触发关闭手势"
    },
    "canEmbed": "内容区域可接受其他非模态子组件拖入（列表、表单、按钮、文本块、图片块等）"
  },

  "builderBehavior": {
    "autoCreateOverlay": true,
    "panelAlign": "flex-end (底部对齐)",
    "dropZone": ".hs-overlay-drop-content",
    "sidebarPreviewScale": 0.45,
    "sidebarControl": "分段选择器切换标准型/把手型"
  },

  "usage": {
    "HSO_A": "需要明确关闭操作的内容展示、表单填写",
    "HSO_B": "支持手势拖拽调整高度的临时内容展示"
  }
}
