{
  "id": "half_screen_overlay",
  "name": "半屏浮层 HalfScreenOverlay",
  "category": "模态",
  "description": "从屏幕底部弹出、约占半屏高度的模态容器组件，用于承载二级内容、表单、选择器等场景。分为标准型（关闭按钮导航栏）和把手型（拖拽把手条）两种子组件。",

  "totalVariants": 2,

  "variants": [
    {
      "id": "HSO-A",
      "name": "标准型",
      "topArea": "A3半屏导航栏（54px，仅关闭按钮右对齐）",
      "heightRange": { "min": 360, "max": 720, "default": 420 },
      "contentHeight": "sheetHeight - 54(导航栏) - 34(HomeBar)",
      "contentHeightDefault": 332,
      "closeMethods": ["点击关闭按钮", "点击蒙层", "下滑手势"]
    },
    {
      "id": "HSO-B",
      "name": "把手型",
      "topArea": "拖拽把手条（20px，居中指示条36×5px）",
      "heightRange": { "fixed": 720 },
      "contentHeight": "720 - 20(把手条) - 34(HomeBar) = 666px",
      "closeMethods": ["下滑手势超过阈值", "点击蒙层"]
    }
  ],

  "layout": {
    "width": 428,
    "topRadius": 20,
    "overlay": "token:overlay_dark",
    "panelBackground": "white",
    "homeBar": { "height": 34, "indicator": { "width": 168.92, "height": 5.71, "radius": 2.85, "color": "token:text_primary", "bottomOffset": 6.72 } }
  },

  "style": {
    "closeButton": {
      "size": 30,
      "radius": "50%",
      "background": "rgba(0,0,0,0.04)",
      "iconSize": 16,
      "iconColor": "token:text_primary",
      "position": "right, padding 16px"
    },
    "handleBar": {
      "areaHeight": 20,
      "indicatorSize": [36, 5],
      "indicatorRadius": 2.5,
      "indicatorColor": "rgba(60,60,67,0.30)",
      "align": "center"
    }
  },

  "interaction": {
    "appear": {
      "panel": "从底部滑入",
      "overlay": "同步淡入",
      "curve": "cubic-bezier(0.32, 0.72, 0.35, 1)",
      "duration": 420
    },
    "dismiss": {
      "panel": "向下滑出",
      "overlay": "同步淡出",
      "duration": 300
    },
    "contentScroll": {
      "overflow": "auto",
      "touchScrolling": "-webkit-overflow-scrolling: touch",
      "scrollTopDismiss": "滚动到顶部后继续下拉触发关闭手势"
    },
    "canEmbed": "内容区域可接受其他非模态子组件拖入（列表、表单、按钮、文本块、图片块等）"
  },

  "builderBehavior": {
    "autoCreateOverlay": true,
    "panelAlign": "flex-end (底部对齐)",
    "dropZone": ".hs-overlay-drop-content",
    "sidebarPreviewScale": 0.45,
    "sidebarControl": "分段选择器切换标准型/把手型"
  },

  "usage": {
    "HSO_A": "需要明确关闭操作的内容展示、表单填写",
    "HSO_B": "支持手势拖拽调整高度的临时内容展示"
  }
}
