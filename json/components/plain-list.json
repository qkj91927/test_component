{
  "id": "list",
  "name": "通栏式列表 Plain List",
  "category": "数据",
  "description": "横向撑满屏幕，适合数据驱动型界面，快速扫描大量同类信息。",
  "spec": "md/LIST_COMPONENT_SPEC.md",

  "totalVariants": 110,
  "theoreticalCombinations": "8×3×10=240",
  "validCombinationCount": 67,
  "multiSelectVariantCount": 43,

  "anatomy": {
    "areas": ["多选控件 Selection Control（可选）", "左侧区域 Left Area", "列表内容 Content Area", "右侧区域 Right Area"]
  },

  "dimensions": {
    "L": [
      { "id": "L0/Empty", "name": "Empty", "size": null, "radius": null, "type": "any" },
      { "id": "L1", "name": "Icon", "size": [24, 24], "radius": 0, "cssClass": "icon-24", "type": "single" },
      { "id": "L2", "name": "File Icon", "size": [52, 52], "radius": 0, "cssClass": "icon-52", "type": "multi" },
      { "id": "L3", "name": "Small Avatar", "size": [32, 32], "radius": "50%", "cssClass": "avatar-32", "type": "single" },
      { "id": "L4", "name": "Medium Avatar", "size": [40, 40], "radius": "50%", "cssClass": "avatar-40", "type": "multi" },
      { "id": "L5", "name": "Large Avatar", "size": [52, 52], "radius": "50%", "cssClass": "avatar-52", "type": "multi" },
      { "id": "L6", "name": "中缩略图", "size": [40, 40], "radius": 8, "cssClass": "thumb-40", "type": "multi" },
      { "id": "L7", "name": "App Icon L", "size": [52, 52], "radius": 0, "cssClass": "icon-52", "type": "multi" }
    ],
    "C": [
      { "id": "C1", "name": "单行", "lines": 1, "rowHeight": 52, "type": "single" },
      { "id": "C2", "name": "双行", "lines": 2, "rowHeight": 72, "type": "multi" },
      { "id": "C3", "name": "三行", "lines": 3, "rowHeight": 72, "type": "multi" }
    ],
    "R": [
      { "id": "R0/Empty", "name": "Empty" },
      { "id": "R1", "name": "辅助+箭头", "structure": ["helperText(optional)", "arrow"], "helperTextOptional": true, "arrowIcon": "icons/chevron_right.svg", "helperStyle": { "fontSize": 17, "color": { "token": "text-secondary", "value": "rgba(60, 60, 67, 0.6)" }, "marginRight": 4 } },
      { "id": "R2", "name": "辅助+头像+箭头", "structure": ["helperText", "avatar:32x32:round", "arrow"], "avatarAsset": "icons/Avatar_32.svg", "arrowIcon": "icons/chevron_right.svg", "avatarMarginRight": 8 },
      { "id": "R3", "name": "辅助+图片+箭头", "structure": ["helperText", "image:32x32:r4", "arrow"], "imageAsset": "icons/Thumbnail_32.svg", "arrowIcon": "icons/chevron_right.svg", "imageRadius": 4, "imageMarginRight": 8 },
      { "id": "R4", "name": "按钮", "style": { "padding": "6px 16px", "radius": 18, "fontSize": 14, "fontWeight": 500, "bg": { "token": "fill-tertiary", "value": "rgba(116, 116, 128, 0.08)" } } },
      { "id": "R5", "name": "Action", "style": { "fontSize": 17, "color": { "token": "text-link", "value": "#214CA5" } } },
      { "id": "R6", "name": "Icon", "visual": "基础操作图标" },
      { "id": "R7", "name": "金额", "style": { "fontFamily": "DIN Alternate", "fontWeight": 700, "fontSize": 20 } },
      { "id": "R8", "name": "步数", "style": { "numberFont": "DIN Alternate 20px", "iconColumn": true, "rankText": "12px", "iconSize": 16 } },
      { "id": "R9", "name": "聊天", "style": { "timeFont": "12px", "timeColor": { "token": "text-secondary", "value": "rgba(60, 60, 67, 0.6)" }, "flexDirection": "column", "alignItems": "flex-end" }, "statusIcon": "icons/remind_mute.svg", "statusIconOptional": true, "statusIconColor": { "token": "icon-secondary", "value": "rgba(60,60,67,0.6)" }, "statusIconNote": "默认 remind_mute.svg，可替换为其他业务图标，颜色统一用 --color-icon-secondary" }
    ],
    "S": [
      { "id": "S0", "name": "无多选（默认）", "description": "不显示选择控件" },
      {
        "id": "S1",
        "name": "多选态",
        "description": "左侧前置 24px 圆形选择控件，点击切换选中/未选中，不重复列举两个静态变体",
        "size": 24,
        "marginRight": 12,
        "unselected": { "icon": "icons/Checkbox.svg" },
        "selected": { "icon": "icons/Checkbox_filled.svg" },
        "interaction": "替换 img.src：Checkbox.svg ↔ Checkbox_filled.svg",
        "allowedR": ["R0", "R1", "R2", "R3", "R6", "R7"]
      }
    ]
  },

  "constraints": [
    { "rule": "single-type (L1,L3) → C = C1", "reason": "单行类型仅匹配单行内容" },
    { "rule": "multi-type (L2,L4,L5,L6,L7) → C ∈ {C2, C3}", "reason": "多行类型仅匹配双行或三行" },
    { "rule": "L0/Empty → C ∈ {C1, C2}, R ∈ {R1, R4, R5, R6}", "reason": "空左侧禁止三行C3，右侧仅限4种" },
    { "rule": "R2 → L = L1, C = C1", "reason": "辅助+头像+箭头仅限 Icon 单行" },
    { "rule": "R3 → C = C1", "reason": "辅助+图片仅限单行" },
    { "rule": "R2/R3 → C = C1", "reason": "辅助+头像/图片类右侧仅限单行，不可与 C2/C3 组合" },
    { "rule": "R1 → C ∈ {C1, C2, C3}", "reason": "辅助+箭头允许与单行/双行/三行搭配" },
    { "rule": "L2 → R = R6", "reason": "File Icon 右侧仅限 Icon" },
    { "rule": "R8, R9 → C = C2", "reason": "步数和聊天仅限双行" },
    { "rule": "R7, R8 → L = L4", "reason": "金额和步数强绑定 Medium Avatar" },
    { "rule": "R9 → L = L5", "reason": "聊天强绑定 Large Avatar" },
    { "rule": "S1(多选态) → L ∈ {L0~L7}（任意），R ∈ {R0, R1, R2, R3, R6, R7}", "reason": "多选态不支持 R4按钮/R5Action/R8步数/R9聊天" }
  ],

  "layout": {
    "display": "flex",
    "alignItems": "center",
    "padding": "0 16px",
    "width": 428,
    "background": { "token": "bg-bottom", "value": "#FFFFFF" },
    "leftAreaMarginRight": 12,
    "rightAreaMarginLeft": 12
  },

  "style": {
    "title": { "fontSize": 17, "lineHeight": 24, "color": { "token": "text-primary", "value": "rgba(0, 0, 0, 1.0)" }, "overflow": "ellipsis", "whiteSpace": "nowrap" },
    "desc": { "fontSize": 14, "lineHeight": 20, "height": 20, "display": "flex", "color": { "token": "text-secondary", "value": "rgba(60, 60, 67, 0.6)" } },
    "descText": { "flexShrink": 1, "minWidth": 0, "overflow": "hidden", "textOverflow": "ellipsis", "whiteSpace": "nowrap", "note": "描述文字+textlink 合并为单一节点，textlink 仅以链接色区分，两者紧挨" },
    "descImg": { "size": 16, "flexShrink": 0, "note": "描述行图标，不被压缩" },
    "textLink": { "color": { "token": "text-link", "value": "#214CA5" }, "flexShrink": 0, "note": "文字链，不被压缩" },
    "helperText": { "maxWidth": 120, "overflow": "hidden", "textOverflow": "ellipsis", "whiteSpace": "nowrap", "note": "右区辅助文字，最大宽度 120px 防止挤压内容区" },
    "descStructure": "C2/C3 描述行默认仅展示描述文本（含可选 textlink），行首 empty.icon 与行尾右箭头默认不展示，可选添加：[行首图标(16px, flex-shrink:0, default:false, 可选)] + 描述文本(必填) + [textlink(嵌套在desc-text内, 可省略)] + [行尾右箭头(16px, flex-shrink:0, default:false, 可选)]；desc-text(flex-shrink:1)超出截断"
  },

  "layoutRules": {
    "structure": "三段式 Flex：[左区 flex-shrink:0] | [内容区 flex:1 min-width:0] | [右区 flex-shrink:0]",
    "contentArea": "flex:1; min-width:0 — 允许被压缩，overflow:hidden 生效",
    "leftArea": "flex-shrink:0 — 图标/头像固定宽度",
    "rightArea": "flex-shrink:0 — 辅助信息固定，helperText 加 max-width:120px 约束",
    "truncationPriority": "内容区（标题/描述文字）优先被压缩截断，左右区固定不压缩"
  },

  "interaction": {
    "tapTarget": "整行为点击热区（L0+R0 除外）",
    "pressed": { "background": { "token": "fill-tertiary", "value": "rgba(0, 0, 0, 0.04)" }, "transition": "100ms ease-out" },
    "released": { "background": { "token": "bg-bottom", "value": "#FFFFFF" }, "transition": "150ms ease-out" }
  },

  "border-weak": {
    "height": 0.5,
    "color": { "token": "border-weak", "value": "rgba(0, 0, 0, 0.05)" },
    "marginLeft": 16,
    "note": "列表行之间，由外部容器控制"
  },

  "compositionRules": {
    "singleType": "同一页面视图中的通栏式列表必须由同一类型的子组件构成",
    "structuralSwitch": "不同类型通过 Tab/Segment 等视图级切换控件展示"
  },

  "textRules": {
    "title": { "maxLines": 1, "overflow": "ellipsis" },
    "desc": { "maxLines": 2, "overflow": "ellipsis" }
  },

  "usage": {
    "primary": "设置页、联系人列表、消息列表等数据驱动型界面",
    "notFor": "任务驱动型界面（应使用卡片式列表）"
  }
}
