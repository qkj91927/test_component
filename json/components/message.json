{
  "id": "message",
  "name": "消息 Message",
  "category": "数据",
  "description": "即时通讯场景的聊天气泡消息组件，由头像区域和气泡内容区域组成。支持主态（头像在右+蓝色气泡）和客态（头像在左+白色气泡），包含4种内容类型。",

  "totalVariants": 8,

  "variants": [
    { "id": "A", "name": "通用文本", "contentType": "text", "keys": ["text_guest", "text_host"], "description": "纯文字气泡，客态白色/主态蓝色" },
    { "id": "B", "name": "图文长描述", "contentType": "rich_long", "keys": ["rich_long_guest", "rich_long_host"], "description": "标题+描述(三行)+App图标+分割线+辅助信息" },
    { "id": "C", "name": "图文短标题", "contentType": "rich_short", "keys": ["rich_short_guest", "rich_short_host"], "description": "标题(两行)+描述(一行)+App图标" },
    { "id": "D", "name": "图标消息", "contentType": "icon_msg", "keys": ["icon_msg_guest", "icon_msg_host"], "description": "左侧图标+标题+分割线+辅助信息" }
  ],

  "modes": {
    "guest": { "label": "客态", "flexDirection": "row", "avatarPosition": "left", "bubbleAlign": "left" },
    "host": { "label": "主态", "flexDirection": "row-reverse", "avatarPosition": "right", "bubbleAlign": "right" }
  },

  "layout": {
    "outerWidth": 428,
    "contentRowWidth": 364,
    "guestMarginLeft": 12,
    "hostMarginRight": 12,
    "verticalPadding": "4px 0",
    "avatarSize": 40,
    "avatarPaddingTop": 8,
    "bubbleGap": 8,
    "bubblePaddingTop": 8
  },

  "bubbleStyles": {
    "text": {
      "description": "纯文字气泡，主/客态颜色不同",
      "maxWidth": 308,
      "borderRadius": 10,
      "padding": 9,
      "fontSize": 17,
      "lineHeight": 24,
      "fontWeight": 400,
      "guest": { "background": "#FFFFFF", "color": "#1A1C1E" },
      "host": { "background": "#0099FF", "color": "#FFFFFF" }
    },
    "structured": {
      "description": "结构化气泡（B/C/D类），主/客态均白色",
      "width": 263,
      "borderRadius": 10,
      "background": "#FFFFFF",
      "contentPadding": 12,
      "title": { "fontSize": 17, "lineHeight": 24, "color": "rgba(0,0,0,0.90)" },
      "separator": { "width": 263, "height": 0.5, "color": "rgba(0,0,0,0.05)" }
    }
  },

  "contentTypes": {
    "rich_long": {
      "description": "标题+描述(最多三行)+右侧52px App图标→分割线→辅助信息行",
      "desc": { "fontSize": 14, "lineHeight": 20, "color": "rgba(60,60,67,0.56)", "marginTop": 4, "maxLines": 3 },
      "icon": { "size": 52, "borderRadius": 12 },
      "auxRow": { "height": 22, "iconSize": 12, "fontSize": 12, "color": "rgba(60,60,67,0.56)" }
    },
    "rich_short": {
      "description": "标题(最多两行)+描述(一行)+右侧52px App图标，无辅助信息行",
      "title": { "maxLines": 2, "fontSize": 17, "lineHeight": 24, "color": "#1A1C1E" },
      "desc": { "fontSize": 12, "lineHeight": 17, "color": "#909094" },
      "icon": { "size": 52, "borderRadius": 12 }
    },
    "icon_msg": {
      "description": "左侧52px图标+标题→分割线→辅助信息行",
      "layout": "flex, align-items: center, gap: 8px",
      "icon": { "size": 52, "borderRadius": 12 },
      "auxRow": { "height": 22, "iconSize": 12, "fontSize": 12, "color": "rgba(60,60,67,0.56)" }
    }
  },

  "assets": {
    "note": "统一使用 icons/ 目录下的通用占位图，不使用 Figma 导出的专属素材",
    "avatar": { "file": "icons/Avatar_40.svg", "size": 40 },
    "thumbnailIcon": { "file": "icons/Thumbnail_52.svg", "size": 52 },
    "emptyIcon": { "file": "icons/empty_icon.svg", "size": 12, "note": "原始24×24px缩放至12px" }
  },

  "segmentedControl": {
    "description": "统一分段选择器，同时控制全部4个变体的主/客态切换",
    "options": ["客态", "主态"],
    "defaultSelected": "客态"
  },

  "constraints": [
    "消息组件外层容器始终为428px宽度",
    "主态与客态的唯一结构差异是flex-direction方向",
    "A类（通用文本）主/客态气泡颜色不同；B/C/D类（结构化气泡）主/客态气泡均为白色",
    "所有结构化气泡宽度固定为263px",
    "头像固定40×40px，气泡内图标固定52×52px（border-radius: 12px）",
    "统一的分段选择器在component-matrix.html和component-builder.html中均使用"
  ]
}
