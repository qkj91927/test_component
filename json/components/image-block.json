{
  "id": "image_block",
  "name": "图片块 ImageBlock",
  "category": "数据",
  "description": "以图片为核心内容的展示区域，支持单图、轮播与多图宫格，用于承载视觉化信息或媒体浏览场景。",

  "totalVariants": 10,

  "variants": {
    "A_fullWidth": [
      { "id": "A1", "name": "单图轮播·短", "imageSize": [428, 200], "containerHeight": 200, "hasDots": true },
      { "id": "A2", "name": "单图轮播·中", "imageSize": [428, 320], "containerHeight": 320, "hasDots": true },
      { "id": "A3", "name": "单图轮播·长", "imageSize": [428, 420], "containerHeight": 420, "hasDots": true },
      { "id": "A4", "name": "四宫格", "imageSize": [428, 428], "containerHeight": 428, "gridCols": 2, "cellSize": [213, 213], "gap": 2, "hasDots": false },
      { "id": "A5", "name": "九宫格", "imageSize": [428, 428], "containerHeight": 428, "gridCols": 3, "cellSize": [141.33, 141.33], "gap": 2, "hasDots": false }
    ],
    "B_inset": [
      { "id": "B1", "name": "单图轮播·短", "imageSize": [396, 200], "containerHeight": 232, "hasDots": true },
      { "id": "B2", "name": "单图轮播·中", "imageSize": [396, 320], "containerHeight": 352, "hasDots": true },
      { "id": "B3", "name": "单图轮播·长", "imageSize": [396, 388], "containerHeight": 420, "hasDots": true },
      { "id": "B4", "name": "四宫格", "imageSize": [396, 396], "containerHeight": 428, "gridCols": 2, "cellSize": [197, 197], "gap": 2, "hasDots": false },
      { "id": "B5", "name": "九宫格", "imageSize": [396, 396], "containerHeight": 428, "gridCols": 3, "cellSize": [130.67, 130.67], "gap": 2, "hasDots": false }
    ]
  },

  "layout": {
    "containerWidth": 428,
    "background": "white",
    "fullWidth": { "imageWidth": 428, "padding": 0 },
    "inset": { "imageWidth": 396, "padding": 16 }
  },

  "pageDots": {
    "count": 6,
    "dotSize": 8,
    "gap": 8,
    "activeColor": { "token": "brand_standard", "value": "#0099FF" },
    "inactiveColor": { "token": "fill_standard_primary", "value": "rgba(13, 16, 49, 0.04)" },
    "position": "absolute, 距图片底部约24px"
  },

  "gridLayout": {
    "positioning": "absolute",
    "gap": 2
  },

  "interaction": {
    "carouselIndicator": {
      "type": "点击切换",
      "trigger": "click",
      "behavior": "点击某个圆点后该圆点变为激活态(active)，其余变为非激活态(inactive)",
      "cssClass": { "active": "dot active", "inactive": "dot inactive" },
      "transition": "background 200ms ease-out",
      "cursor": "pointer",
      "eventDelegation": "document.addEventListener('click', ...) 匹配 .image-block-dots .dot"
    },
    "carouselSwipe": "左右滑动切换图片由业务层实现，滑动时同步更新指示器激活态",
    "gridTap": "点击单张图片打开大图预览由业务层实现"
  },

  "usage": {
    "A1_A2": "Banner 轮播",
    "A3": "详情大图预览",
    "A4_A5": "图片选择器",
    "B1_B2": "卡片内嵌图片",
    "B3": "内容详情配图",
    "B4_B5": "内嵌相册缩略图"
  }
}
