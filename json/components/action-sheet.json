{
  "id": "action_sheet",
  "name": "操作面板 ActionSheet",
  "category": "模态",
  "description": "从底部弹出的模态操作面板，提供一组可选操作与取消按钮，用于上下文操作选择与确认。支持操作提示、常规操作、警示操作三种行类型。",

  "totalVariants": 22,

  "structure": {
    "overlay": { "color": "rgba(0,0,0,0.50)" },
    "mainBlock": { "background": { "token": "bg_item", "value": "#FFFFFF" }, "topRadius": 16 },
    "cancelBlock": { "background": { "token": "bg_item", "value": "#FFFFFF" }, "height": 90, "cancelRow": 56, "homeBar": 34 },
    "gap": { "height": 10, "color": { "token": "bg_secondary", "value": "#F3F3F7" } }
  },

  "rowTypes": {
    "title": {
      "name": "操作提示（标题行）",
      "height": 56,
      "fontSize": 14,
      "fontWeight": 400,
      "color": { "token": "text_secondary", "value": "rgba(60, 60, 67, 0.76)" },
      "align": "center",
      "removable": true,
      "divider": "无（位于第一行时）"
    },
    "action": {
      "name": "常规操作行",
      "height": 56,
      "fontSize": 17,
      "fontWeight": 400,
      "color": { "token": "text_primary", "value": "rgba(0, 0, 0, 0.90)" },
      "align": "center",
      "removable": true,
      "divider": "顶部 0.5px（非第一行时）"
    },
    "danger": {
      "name": "警示操作行",
      "height": 56,
      "fontSize": 17,
      "fontWeight": 400,
      "color": { "token": "feedback_error", "value": "#F74C30" },
      "align": "center",
      "removable": true,
      "divider": "顶部 0.5px"
    },
    "cancel": {
      "name": "取消行",
      "height": 56,
      "fontSize": 17,
      "fontWeight": 400,
      "color": { "token": "text_primary", "value": "rgba(0, 0, 0, 0.90)" },
      "align": "center",
      "removable": false
    }
  },

  "variantFormula": "操作数量(0-5) × 操作提示(有/无) × 警示操作(有/无) = 22 种",

  "variants": [
    { "id": "AS-0D", "title": false, "actionCount": 0, "danger": true, "name": "警示" },
    { "id": "AS-0TD", "title": true, "actionCount": 0, "danger": true, "name": "提示+警示" },
    { "id": "AS-1", "title": false, "actionCount": 1, "danger": false, "name": "1操作" },
    { "id": "AS-1D", "title": false, "actionCount": 1, "danger": true, "name": "1操作+警示" },
    { "id": "AS-1T", "title": true, "actionCount": 1, "danger": false, "name": "提示+1操作" },
    { "id": "AS-1TD", "title": true, "actionCount": 1, "danger": true, "name": "提示+1操作+警示" },
    { "id": "AS-2", "title": false, "actionCount": 2, "danger": false, "name": "2操作" },
    { "id": "AS-2D", "title": false, "actionCount": 2, "danger": true, "name": "2操作+警示" },
    { "id": "AS-2T", "title": true, "actionCount": 2, "danger": false, "name": "提示+2操作" },
    { "id": "AS-2TD", "title": true, "actionCount": 2, "danger": true, "name": "提示+2操作+警示" },
    { "id": "AS-3", "title": false, "actionCount": 3, "danger": false, "name": "3操作" },
    { "id": "AS-3D", "title": false, "actionCount": 3, "danger": true, "name": "3操作+警示" },
    { "id": "AS-3T", "title": true, "actionCount": 3, "danger": false, "name": "提示+3操作" },
    { "id": "AS-3TD", "title": true, "actionCount": 3, "danger": true, "name": "提示+3操作+警示" },
    { "id": "AS-4", "title": false, "actionCount": 4, "danger": false, "name": "4操作" },
    { "id": "AS-4D", "title": false, "actionCount": 4, "danger": true, "name": "4操作+警示" },
    { "id": "AS-4T", "title": true, "actionCount": 4, "danger": false, "name": "提示+4操作" },
    { "id": "AS-4TD", "title": true, "actionCount": 4, "danger": true, "name": "提示+4操作+警示" },
    { "id": "AS-5", "title": false, "actionCount": 5, "danger": false, "name": "5操作" },
    { "id": "AS-5D", "title": false, "actionCount": 5, "danger": true, "name": "5操作+警示" },
    { "id": "AS-5T", "title": true, "actionCount": 5, "danger": false, "name": "提示+5操作" },
    { "id": "AS-5TD", "title": true, "actionCount": 5, "danger": true, "name": "提示+5操作+警示" }
  ],

  "constraints": [
    "操作数量为0时，警示操作不可关闭（至少保留一行可执行操作）",
    "取消按钮不可移除，始终固定在底部"
  ],

  "heightFormula": {
    "mainBlock": "行数 × 56px（行数 = 标题行(0或1) + 常规操作行(0-5) + 警示行(0或1)）",
    "cancelBlock": "56px + 34px(HomeBar) = 90px",
    "total": "mainBlock + 10px间距 + cancelBlock"
  },

  "layout": {
    "width": 428,
    "topRadius": 16,
    "rowHeight": 56,
    "divider": { "height": 0.5, "color": { "token": "separator", "value": "rgba(0, 0, 0, 0.08)" }, "position": "非第一行的顶部" },
    "homeBarIndicator": { "width": 168.92, "height": 5.71, "radius": 2.85, "color": { "token": "text_primary", "value": "rgba(0, 0, 0, 0.90)" }, "bottomOffset": 6.72 }
  },

  "interaction": {
    "appear": "从底部滑入，遮罩层淡入",
    "dismiss": "点击遮罩层或取消按钮，面板向下滑出，遮罩淡出",
    "actionTap": "点击常规操作行：执行操作并收起",
    "dangerTap": "点击警示操作行：可触发二次确认或直接执行",
    "cancelTap": "关闭面板，不执行任何操作"
  },

  "controls": [
    { "type": "分段选择器", "name": "操作数量", "options": [0, 1, 2, 3, 4, 5], "property": "actionCount" },
    { "type": "二态开关", "name": "操作提示", "property": "hasTitle" },
    { "type": "二态开关", "name": "警示操作", "property": "hasDanger" }
  ]
}
