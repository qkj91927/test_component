{
  "id": "button",
  "name": "按钮 Button",
  "category": "操作",
  "description": "移动端最基础的操作触发组件，通过视觉层级（一级/二级/警示）和尺寸变化适配不同交互场景。由 4 种尺寸 × 3 种类型排列组合生成 12 种子组件。",

  "totalVariants": 12,

  "dimensions": {
    "size": [
      { "id": "S1", "name": "大 Large", "width": 320, "height": 48, "radius": 14, "fontSize": 17, "fontWeight": 500 },
      { "id": "S2", "name": "中 Medium", "width": 169, "height": 40, "radius": 12, "fontSize": 17, "fontWeight": 500 },
      { "id": "S3", "name": "小 Small", "width": "min 60px", "height": 32, "radius": 16, "fontSize": 14, "fontWeight": 400 },
      { "id": "S4", "name": "Mini", "width": "min 42px", "height": 24, "radius": 12, "fontSize": 10, "fontWeight": 400 }
    ],
    "type": [
      { "id": "T1", "name": "一级 Primary", "visual": "实心填充蓝色背景，白色文字" },
      { "id": "T2", "name": "二级 Secondary", "visual": "透明背景，灰色描边，黑色文字" },
      { "id": "T3", "name": "警示 Error", "visual": "透明背景，灰色描边，红色文字" }
    ]
  },

  "states": {
    "primary": {
      "default": { "bg": { "token": "brand_standard", "value": "#0099FF" }, "text": { "token": "text_allwhite", "value": "#FFFFFF" }, "border": "none" },
      "pressed": { "bg": { "token": "brand_pressed", "value": "#008AE5" }, "text": { "token": "text_allwhite", "value": "#FFFFFF" }, "border": "none" },
      "loading": { "bg": { "token": "brand_pressed", "value": "#008AE5" }, "text": { "token": "text_allwhite", "value": "#FFFFFF" }, "border": "none" },
      "disabled": { "bg": "rgba(0,153,255,0.50)", "text": "rgba(255,255,255,0.50)", "border": "none" }
    },
    "secondary": {
      "default": { "bg": "transparent", "text": { "token": "text_primary", "value": "rgba(0,0,0,0.90)" }, "border": "rgba(60,60,67,0.25) 1px" },
      "pressed": { "bg": "rgba(204,204,204,0.30)", "text": { "token": "text_primary", "value": "rgba(0,0,0,0.90)" }, "border": "rgba(60,60,67,0.25) 1px" },
      "loading": { "bg": "rgba(204,204,204,0.30)", "text": { "token": "text_primary", "value": "rgba(0,0,0,0.90)" }, "border": "rgba(60,60,67,0.25) 1px" },
      "disabled": { "bg": "rgba(204,204,204,0.30)", "text": "rgba(0,0,0,0.30)", "border": "rgba(60,60,67,0.12) 1px", "opacity": 0.30 }
    },
    "error": {
      "default": { "bg": "transparent", "text": { "token": "feedback_error", "value": "#F74C30" }, "border": "rgba(60,60,67,0.25) 1px" },
      "pressed": { "bg": "rgba(204,204,204,0.30)", "text": { "token": "feedback_error", "value": "#F74C30" }, "border": "rgba(60,60,67,0.25) 1px" },
      "disabled": { "bg": "transparent", "text": "rgba(247,76,48,0.30)", "border": "rgba(60,60,67,0.12) 1px" }
    }
  },

  "stateAvailability": {
    "loading": "仅 S1(大) 和 S2(中) 的 T1(一级) 和 T2(二级) 支持",
    "noLoadingFor": ["S3", "S4", "T3"]
  },

  "loading": {
    "spinner": { "size": 19, "strokeWidth": 2.5, "linecap": "round", "animation": "linear rotate 1s/圈" },
    "primarySpinnerColor": "rgba(255,255,255,0.90)",
    "secondarySpinnerColor": "rgba(0,0,0,0.40)",
    "layout": "spinner 与文案水平排列，间距 4px，整体居中"
  },

  "interaction": {
    "defaultToPressed": "手指触摸/鼠标按下时立即切换",
    "defaultToLoading": "触发异步操作后进入加载态",
    "defaultToDisabled": "上下文不满足操作条件时置灰",
    "loadingBlocked": "加载态期间不可再次点击"
  },

  "usage": {
    "S1": "页面底部操作行，撑满可用宽度",
    "S2": "操作行内与其他按钮并排",
    "S3": "列表行右侧操作区域",
    "S4": "紧凑空间内的轻量操作"
  }
}
