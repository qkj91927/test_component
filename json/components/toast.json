{
  "id": "toast",
  "name": "轻提示 Toast",
  "category": "操作",
  "description": "短暂性的非阻断式反馈提示组件，用于告知用户操作结果或当前状态，无需用户交互即可自动消失。",
  "spec": "md/TOAST_COMPONENT_SPEC.md",

  "totalVariants": 5,

  "variants": [
    { "id": "T1", "name": "加载中",   "icon": "icons/loading.svg",                      "position": "center", "duration": null,  "actionLink": false },
    { "id": "T2", "name": "成功",     "icon": "icons/QUI_24_icons/tick_circle.svg",      "position": "center", "duration": 2000,  "actionLink": false },
    { "id": "T3", "name": "失败",     "icon": "icons/QUI_24_icons/caution_filled.svg",   "position": "center", "duration": 2000,  "actionLink": false },
    { "id": "T4", "name": "中性文字", "icon": null,                                      "position": "center", "duration": 2000,  "actionLink": false },
    { "id": "T5", "name": "带操作",   "icon": "icons/QUI_24_icons/tick_circle.svg",      "position": "bottom", "duration": 3000,  "actionLink": true,  "actionDismiss": true }
  ],

  "layout": {
    "T1_T4": {
      "height": 44,
      "width": "auto",
      "display": "inline-flex",
      "padding": "12px 16px",
      "gap": 4,
      "position": "fixed",
      "left": "50%",
      "top": "50%",
      "transform": "translate(-50%, -50%)"
    },
    "T5": {
      "height": 52,
      "width": 396,
      "display": "flex",
      "justifyContent": "space-between",
      "padding": "12px 16px",
      "gap": 4,
      "position": "fixed",
      "left": "50%",
      "bottom": 64,
      "transform": "translateX(-50%)"
    }
  },

  "style": {
    "container": {
      "background": { "token": "--qq-bg-toast-nonopaque", "value": "rgba(0, 0, 0, 0.60)" },
      "backdropFilter": "blur(20px)",
      "borderRadius": 16
    },
    "mainText": {
      "fontSize": 16,
      "fontWeight": 400,
      "lineHeight": 20,
      "lineHeightT5": 22,
      "color": { "token": "--color-text-allwhite", "value": "#ffffff" }
    },
    "actionLink": {
      "fontSize": 14,
      "fontWeight": 400,
      "lineHeight": 22,
      "color": { "token": "brand-standard", "value": "#0099FF" }
    },
    "icon": {
      "size": 24,
      "color": { "token": "--qq-icon-allwhite-primary", "value": "#ffffff" },
      "cssFilter": "brightness(0) invert(1)"
    },
    "loadingAnimation": {
      "keyframes": "toast-spin",
      "duration": "1s",
      "timingFunction": "linear",
      "iterationCount": "infinite"
    }
  },

  "animation": {
    "centerEntry":  { "duration": 250, "easing": "ease", "opacity": "0→1", "scale": "0.92→1" },
    "centerExit":   { "duration": 250, "easing": "ease", "opacity": "1→0", "scale": "1→0.92" },
    "bottomEntry":  { "duration": 300, "easing": "ease", "opacity": "0→1", "translateY": "8px→0" },
    "bottomExit":   { "duration": 300, "easing": "ease", "opacity": "1→0", "translateY": "0→8px" }
  },

  "interaction": {
    "nonBlocking": true,
    "noOverlay": true,
    "singleInstance": true,
    "T1_manualDismiss": true,
    "T5_actionDismiss": "点击操作文字链立即消失，不等待 duration"
  }
}
