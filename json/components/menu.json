{
  "id": "menu",
  "name": "菜单 Menu",
  "category": "操作",
  "description": "伴随式非模态浮层菜单，出现在触发元素上方或下方 6px 位置，提供一组可选操作项。支持有图标、无图标和有勾选三种样式，选项数量 2-6 个。",
  "spec": "md/MENU_COMPONENT_SPEC.md",

  "totalVariants": 15,

  "subtypes": {
    "I": { "name": "有图标 With Icon", "rowHeight": 52, "iconSize": 24, "iconLeft": 20, "textLeft": 60 },
    "NI": { "name": "无图标 Without Icon", "rowHeight": 52, "textLeft": 20 },
    "C": { "name": "有勾选 With Checkmark", "rowHeight": 52, "textLeft": 20, "checkmarkSize": 20, "checkmarkRight": 20, "checkmarkColor": "#0099FF", "checkmarkFile": "icons/tick.svg" }
  },

  "optionCounts": [2, 3, 4, 5, 6],

  "variantMatrix": [
    { "id": "I-2", "type": "I", "options": 2, "height": 104 },
    { "id": "I-3", "type": "I", "options": 3, "height": 156 },
    { "id": "I-4", "type": "I", "options": 4, "height": 208 },
    { "id": "I-5", "type": "I", "options": 5, "height": 260 },
    { "id": "I-6", "type": "I", "options": 6, "height": 312 },
    { "id": "NI-2", "type": "NI", "options": 2, "height": 104 },
    { "id": "NI-3", "type": "NI", "options": 3, "height": 156 },
    { "id": "NI-4", "type": "NI", "options": 4, "height": 208 },
    { "id": "NI-5", "type": "NI", "options": 5, "height": 260 },
    { "id": "NI-6", "type": "NI", "options": 6, "height": 312 },
    { "id": "C-2", "type": "C", "options": 2, "height": 104 },
    { "id": "C-3", "type": "C", "options": 3, "height": 156 },
    { "id": "C-4", "type": "C", "options": 4, "height": 208 },
    { "id": "C-5", "type": "C", "options": 5, "height": 260 },
    { "id": "C-6", "type": "C", "options": 6, "height": 312 }
  ],

  "layout": {
    "containerWidth": 180,
    "radius": 12,
    "background": { "token": "bg-bottom", "value": "#FFFFFF" },
    "shadow": { "token": "shadow.menu", "value": "0 8px 32px rgba(0,0,0,0.12)" }
  },

  "style": {
    "text": { "fontSize": 17, "fontWeight": 400, "color": { "token": "text-primary", "value": "rgba(0, 0, 0, 1.0)" }, "font": "PingFang SC" }
  },

  "interaction": {
    "positioning": {
      "preferBelow": true,
      "offset": 6,
      "fallback": "空间不足时切换到触发元素上方"
    },
    "nonModal": {
      "noOverlay": true,
      "backgroundInteractable": true,
      "notBlocking": true
    },
    "animation": {
      "appear": { "opacity": "0→1", "transform": "scale(0.9)→scale(1)", "duration": 200, "easing": "ease-out", "transformOrigin": "触发点方向" },
      "disappear": { "opacity": "1→0", "transform": "scale(1)→scale(0.9)", "duration": 150, "easing": "ease-in", "transformOrigin": "触发点方向" }
    },
    "closeOn": ["点击菜单项", "点击菜单外任意区域", "ESC键(桌面端)", "页面滚动"],
    "checkmarkRule": "单选互斥 — 同一时刻仅一个选中态"
  },

  "triggerContext": {
    "groupedList_R2": "卡片式列表 R2(下拉菜单) 点击后弹出有勾选菜单(C类型)",
    "dataFilter_C1": "数据筛选 C1(下拉筛选) 点击下拉触发器后弹出无图标菜单",
    "navbar_R1R2": "导航栏 R1/R2(更多图标) 点击后弹出有图标或无图标菜单"
  },

  "controls": [
    { "type": "分段选择器", "name": "类型", "options": ["有图标", "无图标", "有勾选"], "default": "有图标" },
    { "type": "分段选择器", "name": "选项数量", "options": [2, 3, 4, 5, 6], "default": 3 }
  ]
}
