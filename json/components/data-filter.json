{
  "id": "data_filter",
  "name": "数据筛选 DataFilter",
  "category": "数据",
  "description": "页面中用于分类切换、条件筛选与层级导航的组合组件族，包含页签、分段选择、下拉筛选、标签、面包屑五种子组件类型。",
  "spec": "md/DATA_FILTER_COMPONENT_SPEC.md",

  "totalVariants": 16,

  "variants": {
    "A_tab": {
      "name": "页签 Tab",
      "items": [
        { "id": "A1", "name": "四页签", "count": 4, "height": 24, "mode": "equal" },
        { "id": "A2", "name": "五页签", "count": 5, "height": 24, "mode": "equal" },
        { "id": "A3", "name": "六页签", "count": 6, "height": 24, "mode": "equal" },
        { "id": "A4", "name": "横滑", "count": 8, "height": 24, "mode": "scroll", "padding": "0 16px", "gap": 24 }
      ],
      "layout": {
        "containerWidth": 428,
        "background": "transparent",
        "bottomBorder": { "height": 0.5, "color": { "token": "border-default", "value": "#C6C6C8" } },
        "overflow": "hidden"
      },
      "style": {
        "text": { "fontSize": 16, "lineHeight": 22, "font": "PingFang SC" },
        "unselected": { "fontWeight": 400, "color": { "token": "text-primary", "value": "rgba(0, 0, 0, 1.0)" } },
        "selected": { "fontWeight": 500, "color": { "token": "text-primary", "value": "rgba(0, 0, 0, 1.0)" } },
        "indicator": { "width": 32, "height": 3, "radius": 1.5, "color": { "token": "brand-standard", "value": "#0099FF" }, "position": "absolute bottom:0" }
      }
    },

    "B_segment": {
      "name": "分段选择 Segment",
      "items": [
        { "id": "B1", "name": "二选项", "count": 2 },
        { "id": "B2", "name": "三选项", "count": 3 },
        { "id": "B3", "name": "四选项", "count": 4 },
        { "id": "B4", "name": "五选项", "count": 5 }
      ],
      "layout": {
        "outerRow": { "display": "inline-flex", "background": "transparent", "padding": "0 16px" },
        "container": { "display": "inline-flex", "background": { "token": "fill-tertiary", "value": "rgba(118, 118, 128, 0.12)" }, "radius": 12 },
        "barHeight": 40,
        "itemWidth": 52,
        "totalWidth": "52.5 × n"
      },
      "style": {
        "divider": { "width": 0.5, "height": 16, "color": { "token": "border-default", "value": "#C6C6C8" }, "selectedAdjacentHidden": true, "transition": "opacity 200ms ease-out" },
        "text": { "fontSize": 14, "lineHeight": 20, "font": "PingFang SC" },
        "unselected": { "fontWeight": 400, "color": { "token": "text-secondary", "value": "rgba(60, 60, 67, 0.6)" } },
        "selected": { "fontWeight": 500, "color": { "token": "text-primary", "value": "#1A1C1E" }, "background": { "token": "bg-bottom", "value": "#FFFFFF" }, "boxShadow": "0 1px 4px rgba(0,0,0,0.08), 0 0.5px 1px rgba(0,0,0,0.04)" },
        "transition": "all 200ms ease-out"
      }
    },

    "C_dropdown": {
      "name": "下拉筛选 Dropdown",
      "items": [
        { "id": "C1", "name": "一按钮", "count": 1 }
      ],
      "layout": {
        "outerRow": { "display": "inline-flex", "background": "transparent", "padding": "0 16px", "boxSizing": "border-box" },
        "container": { "display": "inline-flex", "background": { "token": "fill-tertiary", "value": "rgba(118, 118, 128, 0.12)" }, "radius": 12 },
        "buttonHeight": 40,
        "buttonPadding": "0 12px",
        "innerGap": 4
      },
      "style": {
        "text": { "fontSize": 14, "lineHeight": 20, "fontWeight": 400, "color": { "token": "text-primary", "value": "rgba(0, 0, 0, 1.0)" } },
        "arrow": { "size": 14, "fill": "#000000", "file": "icons/chevron_down.svg" }
      },
      "note": "仅包含按钮，不包含弹窗菜单。点击后由 Menu 组件承担弹窗"
    },

    "D_tag": {
      "name": "标签 Tag",
      "items": [
        { "id": "D1", "name": "单行横滑", "count": 6, "height": 40, "tagHeight": 40, "mode": "scroll", "tagPadding": "0 16px" },
        { "id": "D2", "name": "单行4个", "count": 4, "height": 40, "tagHeight": 40, "mode": "tile" },
        { "id": "D3", "name": "单行3个", "count": 3, "height": 40, "tagHeight": 40, "mode": "tile" },
        { "id": "D4", "name": "单行2个", "count": 2, "height": 40, "tagHeight": 40, "mode": "tile" },
        { "id": "D5", "name": "双行2个", "count": 2, "height": 62, "tagHeight": 62, "mode": "tile", "hasDescription": true }
      ],
      "layout": {
        "containerWidth": 428,
        "background": "transparent",
        "tilePadding": "0 16px",
        "scrollPadding": "0",
        "tagAreaWidth": 396,
        "tagRadius": 12,
        "tagBg": { "token": "fill-tertiary", "value": "rgba(118, 118, 128, 0.12)" },
        "tagGap": 8,
        "tileTagWidth": "(396 - (n-1)×8) / n"
      },
      "style": {
        "singleLineText": { "fontSize": 15, "lineHeight": 20, "font": "PingFang SC" },
        "unselected": { "fontWeight": 400, "color": "rgba(60,60,67,0.6)" },
        "selected": { "fontWeight": 500, "color": "rgba(0,0,0,1.0)" },
        "doubleLineTitle": { "fontSize": 15, "lineHeight": 20 },
        "doubleLineDesc": { "fontSize": 14, "lineHeight": 20, "fontWeight": 400 },
        "doubleLineDescSelected": { "color": "rgba(60,60,67,0.6)" },
        "doubleLineDescUnselected": { "color": "rgba(60,60,67,0.3)" }
      }
    },

    "E_breadcrumb": {
      "name": "面包屑 Breadcrumb",
      "items": [
        { "id": "E1", "name": "标准", "levels": 4, "height": 24 },
        { "id": "E2", "name": "超限渐隐", "levels": 6, "height": 24, "overflowMask": true }
      ],
      "layout": {
        "containerWidth": 428,
        "background": "transparent",
        "standardPadding": "0 16px",
        "E2_clipWidth": 412,
        "E2_offset": -92,
        "E2_maskWidth": 24,
        "E2_maskImage": "linear-gradient(to right, transparent 0%, black 24px)"
      },
      "style": {
        "text": { "fontSize": 14, "lineHeight": 20, "fontWeight": 500, "whiteSpace": "nowrap", "flexShrink": 0 },
        "middleLevel": { "color": { "token": "text-tertiary", "value": "rgba(60, 60, 67, 0.6)" } },
        "lastLevel": { "color": { "token": "text-primary", "value": "rgba(0, 0, 0, 1.0)" } },
        "border-weak": { "size": 12, "color": "rgba(60,60,67,0.75)", "margin": "0 8px" }
      }
    }
  },

  "compositionRules": {
    "segmentAndDropdown": "外层 inline-flex, 透明背景, padding: 6px 16px, 宽度自适应",
    "sameLine": "相同/不同类型可同行排列，间距 16px"
  },

  "interaction": {
    "tab": {
      "type": "点击切换",
      "trigger": "click",
      "behavior": "点击页签项后添加 .selected class，其余移除",
      "cssToggle": "互斥式 — 同一时刻仅一个 .selected",
      "eventDelegation": "document.addEventListener('click', ...) 匹配 .df-tab-item"
    },
    "segment": {
      "type": "点击切换",
      "trigger": "click",
      "behavior": "点击分段选项后切换选中态，选中项相邻分隔线隐藏",
      "transition": "all 200ms ease-out"
    },
    "tag": {
      "type": "点击切换",
      "trigger": "click",
      "behavior": "点击标签后添加 .selected class，其余移除"
    },
    "segmentDivider": "选中项左右相邻分隔线 opacity: 0，其余恢复 1",
    "tabIndicator": "仅 .selected 项指示器可见",
    "breadcrumbMask": "E2 通过 .overflow-left class 启用 mask-image 渐隐，不依赖背景色",
    "scrollMode": "A4/D1 支持横向滚动，scrollbar 隐藏，-webkit-overflow-scrolling: touch",
    "dropdown": "组件仅渲染按钮态，点击弹出菜单由业务层实现",
    "breadcrumb": "点击非当前级别目录项的页面导航由业务层实现"
  },

  "usage": {
    "tab": "顶部或区域级信息分类切换",
    "segment": "同级视图的模式切换（日/周/月/年）",
    "dropdown": "条件筛选或排序切换，点击后弹出菜单",
    "tag": "分类标签入口",
    "breadcrumb": "多级层级导航回溯"
  }
}
