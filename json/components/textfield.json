{
  "id": "textfield",
  "name": "输入框 Textfield",
  "category": "操作",
  "description": "表单场景中最基础的信息录入组件，支持多种输入类型与交互状态，满足不同数据采集需求。",
  "spec": "md/TEXTFIELD_COMPONENT_SPEC.md",

  "totalVariants": 50,

  "dimensions": {
    "type": [
      { "id": "A", "name": "单行无标题", "scene": "搜索、备注等简单输入" },
      { "id": "B", "name": "单行有标题", "scene": "表单填写（姓名、地址等）", "titleWidth": 90, "titleGap": 24, "inputAreaWidth": 250 },
      { "id": "C", "name": "电话号码", "scene": "手机号/电话号码输入", "prefix": "中国+86", "prefixColor": { "token": "text-link", "value": "#214CA5" }, "inputAreaWidth": 275 },
      { "id": "D", "name": "多行文本", "scene": "长文本输入（评论、描述等）" },
      { "id": "E", "name": "复合输入框 Advanced Textfield", "scene": "高级编辑场景（发帖、评论配图等）", "subTypes": [
        { "id": "E1", "layout": "card", "hasImage": false, "hasFinish": false, "name": "卡片·基础" },
        { "id": "E2", "layout": "card", "hasImage": true,  "hasFinish": false, "name": "卡片·图片" },
        { "id": "E3", "layout": "card", "hasImage": false, "hasFinish": true,  "name": "卡片·完成" },
        { "id": "E4", "layout": "card", "hasImage": true,  "hasFinish": true,  "name": "卡片·图片+完成" },
        { "id": "E5", "layout": "full", "hasImage": false, "hasFinish": false, "name": "通栏·基础" },
        { "id": "E6", "layout": "full", "hasImage": true,  "hasFinish": false, "name": "通栏·图片" }
      ], "states": ["default", "focused", "typing", "completed", "error"], "height": 420 }
    ],
    "state": [
      { "id": "1", "name": "默认态", "hasCursor": false, "hasClear": false, "placeholder": true },
      { "id": "2", "name": "激活态", "hasCursor": true, "hasClear": false, "placeholder": true },
      { "id": "3", "name": "输入态", "hasCursor": true, "hasClear": true, "placeholder": false, "charCount": "已输入/总数" },
      { "id": "4", "name": "完成态", "hasCursor": false, "hasClear": false, "placeholder": false },
      { "id": "5", "name": "错误态", "hasCursor": true, "hasClear": true, "placeholder": false, "charCountColor": { "token": "accent-red", "value": "#E0462C" } }
    ]
  },

  "singleLineLayout": {
    "totalWidth": 428,
    "rowHeight": 56,
    "roundDecorSize": [16, 56],
    "inputAreaWidth": 364,
    "bottomHelperHeight": 24,
    "totalHeight": 80,
    "bottomDivider": { "width": 364, "height": 0.5, "note": "仅嵌入 Grouped List 时由列表容器添加，单独使用无分割线" }
  },

  "multiLineLayout": {
    "totalWidth": 428,
    "textAreaHeight": 197,
    "contentHeight": 144,
    "padding": 16,
    "radius": 12,
    "charCountPosition": "文本域内右下角",
    "bottomHelperHeight": 24,
    "helperVisible": "optional",
    "totalHeight": "197 | 221",
    "totalHeightNote": "隐藏附加说明时 197px，显示时 221px（197 + 24）"
  },

  "advancedTextfieldLayout": {
    "_comment": "E类由三个Figma属性变量组合定义：Layout × HasImage × HasFinish",
    "totalWidth": 428,
    "totalHeight": 420,
    "elementGap": 16,

    "layout": {
      "card": {
        "width": 396,
        "margin": "0 16px",
        "background": "#ffffff",
        "borderRadius": 24,
        "padding": "24px 16px 16px",
        "hasActionBar": true,
        "pageBackgroundRequired": { "token": "bg-secondary", "value": "#F2F2F7" }
      },
      "full": {
        "width": 428,
        "background": "transparent",
        "padding": "24px 16px 16px",
        "hasActionBar": false,
        "note": "通栏式无底部操作栏，跟随页面背景色"
      }
    },

    "hasImage": {
      "false": {
        "note": "不影响操作栏按钮数量"
      },
      "true": {
        "note": "不影响操作栏按钮数量",
        "imageRow": {
          "marginTop": 16,
          "gap": 12,
          "overflowX": "auto",
          "overflowY": "hidden",
          "scrollbarWidth": "none",
          "webkitScrollbar": "display:none",
          "addButton": {
            "size": 88,
            "background": "rgba(118,118,128,0.12)",
            "borderRadius": 16,
            "iconSize": 24,
            "position": "始终在最左侧"
          },
          "thumbnail": {
            "file": "icons/Thumbnail_88.svg",
            "size": 88,
            "borderRadius": 12
          }
        }
      }
    },

    "hasFinish": {
      "false": {
        "actionBarButtonCount": 3,
        "finishIndicator": null
      },
      "true": {
        "note": "仅 card 类型支持",
        "actionBarButtonCount": 2,
        "finishIndicator": {
          "file": "icons/done.svg",
          "size": 40,
          "opacityByState": {
            "default": 0.3,
            "focused": 0.3,
            "typing": 1,
            "completed": 1,
            "error": 1
          }
        }
      }
    },

    "actionBarButtonCountTable": {
      "_comment": "由 hasFinish 决定，hasImage 不影响数量",
      "E1": 3, "E2": 3, "E3": 2, "E4": 2, "E5": 0, "E6": 0
    },

    "textArea": {
      "withFinish":    { "fontSize": 20, "lineHeight": 28, "applies": ["E3", "E4"] },
      "withoutFinish": { "fontSize": 17, "lineHeight": 24, "applies": ["E1", "E2", "E5", "E6"] },
      "color": { "token": "text-primary", "value": "rgba(0,0,0,1.0)" },
      "cursor": {
        "width": 1,
        "height": "1.2em",
        "color": { "token": "brand-standard", "value": "#0099FF" },
        "verticalAlign": "text-bottom"
      },
      "wordBreak": "break-all"
    },

    "actionBar": {
      "marginTop": 16,
      "gap": 12,
      "button": {
        "padding": "8px 12px",
        "background": "rgba(118,118,128,0.12)",
        "borderRadius": 24,
        "iconSize": 24,
        "fontSize": 17,
        "color": { "token": "text-primary", "value": "rgba(0,0,0,1.0)" }
      },
      "charCount": {
        "fontSize": 12,
        "color": { "token": "text-tertiary", "value": "rgba(60,60,67,0.3)" },
        "errorColor": { "token": "accent-red", "value": "#E0462C" }
      }
    }
  },

  "style": {
    "placeholder": { "fontSize": 17, "fontWeight": 400, "color": { "token": "text_quaternary", "value": "rgba(60,60,67,0.18)" } },
    "inputText": { "fontSize": 17, "fontWeight": 400, "color": { "token": "text-primary", "value": "rgba(0, 0, 0, 1.0)" } },
    "titleText": { "fontSize": 17, "fontWeight": 400, "color": { "token": "text-primary", "value": "rgba(0, 0, 0, 1.0)" } },
    "helperText": { "fontSize": 14, "fontWeight": 400, "color": { "token": "text-tertiary", "value": "rgba(60, 60, 67, 0.3)" } },
    "charCount_single": { "fontSize": 14, "fontWeight": 400, "color": { "token": "text-tertiary", "value": "rgba(60, 60, 67, 0.3)" } },
    "charCount_multi": { "fontSize": 12, "fontWeight": 400, "color": { "token": "text-tertiary", "value": "rgba(60, 60, 67, 0.3)" } },
    "cursor": { "width": 1, "height": 18, "color": { "token": "brand-standard", "value": "#0099FF" } },
    "clearButton": { "size": 20, "color": { "token": "icon-secondary", "value": "rgba(60,60,67,0.6)" } },
    "divider": { "color": { "token": "border-default", "value": "#C6C6C8" } },
    "inputBackground": "white"
  },

  "stateTransitions": {
    "default→focused": "点击/聚焦",
    "focused→typing": "开始输入",
    "typing→completed": "失去焦点",
    "typing→error": "字数超限",
    "completed→focused": "再次聚焦",
    "error→typing": "删减文字"
  },

  "interaction": {
    "helperRow": "所有类型均支持底部附加说明行",
    "charCountFormat": { "defaultFocused": "N字", "typingCompletedError": "已输入/N字" },
    "clearAction": "点击后清空内容，回到激活态"
  }
}
